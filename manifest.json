{
  "manifest_version": 3,
  "name": "DKaraoke for YouTube",
  "version": "0.0.1",
  "description": "A karaoke workspace for YouTube.",
  "key": "",
  "permissions": ["storage", "cookies", "nativeMessaging"],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.youtube.com/*",
    "https://accounts.google.com/*",
    "https://youtu.be/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["styles.css"],
      "js": [
        "src/content/state.js",
        "src/content/settings.js",
        "src/content/lyrics.js",
        "src/content/queue.js",
        "src/content/monitor.js",
        "src/content/status.js",
        "src/content/audio.js",
        "src/content/backend.js",
        "src/content/ui.js",
        "src/content/bootstrap.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["logo.png", "star.svg", "jagged_star.svg", "lines.svg"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
